# Adago Stay redirect rules generated for 1:1 deployment
# Prefer this file on Apache/LiteSpeed hosting to force hard 301 redirects.

<IfModule mod_rewrite.c>
RewriteEngine On
RewriteRule ^antracyt/?$ https://adagostay.pl/pl/apartament/antracyt/ [R=301,L,NE]
RewriteRule ^gold/?$ https://adagostay.pl/pl/apartament/gold/ [R=301,L,NE]
RewriteRule ^oaza/?$ https://adagostay.pl/pl/apartament/oaza/ [R=301,L,NE]
RewriteRule ^pl/nocleg\-szczawno\-zdroj/?$ https://adagostay.pl/pl/noclegi-szczawno-zdroj/ [R=301,L,NE]
RewriteRule ^pl/blog/nocleg\-walbrzych/?$ https://adagostay.pl/pl/noclegi-walbrzych/ [R=301,L,NE]
RewriteRule ^pl/blog/nocleg\-walbrzych\-centrum/?$ https://adagostay.pl/pl/noclegi-walbrzych/ [R=301,L,NE]
RewriteRule ^pl/blog/apartamenty\-walbrzych/?$ https://adagostay.pl/pl/noclegi-walbrzych/ [R=301,L,NE]
RewriteRule ^pl/blog/noclegi\-walbrzych\-tanio/?$ https://adagostay.pl/pl/noclegi-walbrzych/ [R=301,L,NE]
RewriteRule ^pl/blog/wynajem\-krotkoterminowy\-walbrzych/?$ https://adagostay.pl/pl/noclegi-walbrzych/ [R=301,L,NE]
RewriteRule ^pl/blog/noclegi\-dla\-firm\-walbrzych/?$ https://adagostay.pl/pl/blog/apartament-dla-firm-w-walbrzychu/ [R=301,L,NE]
RewriteRule ^pl/blog/apartamenty\-na\-doby\-walbrzych/?$ https://adagostay.pl/pl/noclegi-walbrzych/ [R=301,L,NE]
RewriteRule ^pl/blog/gdzie\-spac\-w\-walbrzychu/?$ https://adagostay.pl/pl/noclegi-walbrzych/ [R=301,L,NE]
RewriteRule ^pl/blog/gdzie\-nocowac\-walbrzych/?$ https://adagostay.pl/pl/noclegi-walbrzych/ [R=301,L,NE]
RewriteRule ^pl/blog/najlepszy\-nocleg\-walbrzych/?$ https://adagostay.pl/pl/noclegi-walbrzych/ [R=301,L,NE]
RewriteRule ^pl/blog/hotel\-czy\-apartament\-walbrzych/?$ https://adagostay.pl/pl/blog/apartament-czy-hotel-co-sprawdzi-sie-lepiej/ [R=301,L,NE]
RewriteRule ^pl/blog/nocleg\-na\-weekend\-walbrzych/?$ https://adagostay.pl/pl/noclegi-walbrzych/ [R=301,L,NE]
RewriteRule ^pl/blog/nocleg\-dla\-par\-walbrzych/?$ https://adagostay.pl/pl/noclegi-walbrzych/ [R=301,L,NE]
RewriteRule ^pl/blog/nocleg\-dla\-pracownikow\-walbrzych/?$ https://adagostay.pl/pl/blog/apartament-dla-firm-w-walbrzychu/ [R=301,L,NE]
RewriteRule ^pl/blog/gdzie\-zatrzymac\-sie\-w\-walbrzychu/?$ https://adagostay.pl/pl/noclegi-walbrzych/ [R=301,L,NE]
RewriteRule ^pl/blog/tani\-nocleg\-walbrzych\-centrum/?$ https://adagostay.pl/pl/noclegi-walbrzych/ [R=301,L,NE]
RewriteRule ^pl/blog/nocleg\-blisko\-zamku\-ksiaz/?$ https://adagostay.pl/pl/noclegi-walbrzych/ [R=301,L,NE]
RewriteRule ^pl/blog/noclegi\-szczawno\-zdroj\-centrum/?$ https://adagostay.pl/pl/noclegi-szczawno-zdroj/ [R=301,L,NE]
RewriteRule ^pl/blog/apartamenty\-szczawno\-zdroj/?$ https://adagostay.pl/pl/noclegi-szczawno-zdroj/ [R=301,L,NE]
RewriteRule ^pl/blog/gdzie\-spac\-blisko\-ksiaza/?$ https://adagostay.pl/pl/noclegi-walbrzych/ [R=301,L,NE]
RewriteRule ^pl/blog/noclegi\-okolice\-walbrzycha/?$ https://adagostay.pl/pl/noclegi-walbrzych/ [R=301,L,NE]
RewriteRule ^pl/blog/nocleg\-dolny\-slask\-walbrzych/?$ https://adagostay.pl/pl/noclegi-walbrzych/ [R=301,L,NE]
RewriteRule ^pl/blog/apartamenty\-blisko\-uzdrowiska/?$ https://adagostay.pl/pl/noclegi-szczawno-zdroj/ [R=301,L,NE]
RewriteRule ^pl/blog/nocleg\-blisko\-atrakcji\-walbrzych/?$ https://adagostay.pl/pl/noclegi-walbrzych/ [R=301,L,NE]
RewriteRule ^pl/blog/nocleg\-na\-wyjazd\-sluzbowy\-walbrzych/?$ https://adagostay.pl/pl/blog/apartament-dla-firm-w-walbrzychu/ [R=301,L,NE]
RewriteRule ^pl/blog/apartamenty\-dla\-turystow\-walbrzych/?$ https://adagostay.pl/pl/noclegi-walbrzych/ [R=301,L,NE]
RewriteRule ^pl/blog/nocleg\-na\-jedna\-noc\-walbrzych/?$ https://adagostay.pl/pl/noclegi-walbrzych/ [R=301,L,NE]
RewriteRule ^pl/blog/apartament\-z\-parkingiem\-walbrzych/?$ https://adagostay.pl/pl/noclegi-walbrzych/ [R=301,L,NE]
RewriteRule ^pl/blog/self\-check\-in\-walbrzych/?$ https://adagostay.pl/pl/blog/self-check-in-co-warto-wiedziec/ [R=301,L,NE]
RewriteRule ^pl/blog/bezposrednia\-rezerwacja\-apartamentu\-walbrzych/?$ https://adagostay.pl/pl/blog/bezposrednia-rezerwacja-dlaczego-warto/ [R=301,L,NE]
</IfModule>

# Force removal of /index.html variants
<IfModule mod_rewrite.c>
RewriteCond %{THE_REQUEST} \s/+(.*/)?index\.html[?\s] [NC]
RewriteRule ^(.*/)?index\.html$ /$1 [R=301,L,NE]
</IfModule>
